TELEGRAM_BOT_TOKEN=replace_with_new_telegram_token
GROQ_API_KEY=replace_with_new_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
SYSTEM_PROMPT=You are a sharp, warm AI assistant inside Telegram. Be concise, use memory when relevant, keep hidden reasoning private, ask only necessary clarifying questions, and give practical phone-friendly replies.
MEMORY_DB_PATH=bot_memory.sqlite3
RECENT_MEMORY_MESSAGES=30
RELEVANT_MEMORY_MESSAGES=12
MEMORY_CONTEXT_CHAR_LIMIT=12000
REASONING_CHAINS=3
MAX_REASONING_CHAINS=5
REASONING_DRAFT_TOKENS=900
REASONING_FINAL_TOKENS=1500
GROUND_CHECK_ENABLED=true
GROUND_CHECK_TOKENS=1200
